# ========================                                                                                                                                                          
# MongoDB       
# ========================
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=your-mongo-password-here

# Per dev locale (localhost)
# MONGO_URI=mongodb://admin:your-mongo-password-here@localhost:27017/linkvault?authSource=admin
# Per Docker (hostname = nome servizio)
MONGO_URI=mongodb://admin:your-mongo-password-here@mongo:27017/linkvault?authSource=admin

# ========================
# Server
# ========================
PORT=3000
NODE_ENV=production

# ========================
# Auth
# ========================
# Genera con: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here

# Genera con: npx bcrypt-cli "your-password" 10
PASSWORD_HASH=your-bcrypt-hash-here

# ========================
# CORS
# ========================
# Dev: http://localhost:5173
# Docker (same-origin via Nginx): http://localhost
CORS_ORIGIN=http://localhost